#!/usr/bin/env bash
# Pre-commit hook: prevent accidental secret commits
set -e

# Patterns that should never be committed
PATTERNS=(
    'PRIVATE.KEY'
    'BEGIN RSA PRIVATE KEY'
    'BEGIN OPENSSH PRIVATE KEY'
    'sk_live_'
    'sk_test_'
    'AKIA[A-Z0-9]{16}'  # AWS access key
    'AIza[A-Za-z0-9_-]{35}'  # GCP API key
    'password\s*=\s*["\x27][^"\x27]{8,}["\x27]'  # password = "..." (8+ chars, skip short test passwords)
)

# Files to check (staged files only)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0

for pattern in "${PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | xargs grep -lE "$pattern" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        # Exclude known safe files
        for file in $MATCHES; do
            case "$file" in
                *.md|*.spec.ts|*.test.*|*seed-demo*|.githooks/*|tests/load/*|scripts/provision-*)
                    continue
                    ;;
                *)
                    echo "WARNING: Potential secret found in: $file (pattern: $pattern)"
                    FOUND_SECRETS=1
                    ;;
            esac
        done
    fi
done

if [ "$FOUND_SECRETS" -eq 1 ]; then
    echo ""
    echo "Commit blocked: potential secrets detected."
    echo "If these are false positives, use: git commit --no-verify"
    exit 1
fi

exit 0
