{
  "expo": {
    "name": "K-Charge",
    "slug": "klc-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "klc",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D9B3A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.klc.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "K-Charge needs your location to find nearby charging stations.",
        "NSCameraUsageDescription": "K-Charge needs camera access to scan QR codes at charging stations."
      }
    },
    "android": {
      "package": "vn.klc.driver",
      "adaptiveIcon": {
        "backgroundColor": "#2D9B3A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow K-Charge to access your camera to scan QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "klc-driver"
      }
    }
  }
}
