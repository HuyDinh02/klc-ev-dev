{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=KLC;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Auth": {
    "Authority": "https://localhost:44305",
