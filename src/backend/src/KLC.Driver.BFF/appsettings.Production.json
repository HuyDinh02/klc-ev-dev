{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "KLC": "Information"
    }
  },
  "AllowedHosts": "bff.ev.odcall.com;*.a.run.app",
  "Auth": {
    "Authority": "https://api.ev.odcall.com",
    "Audience": "KLC"
  },
  "Jwt": {
    "Issuer": "KLC.Driver.BFF",
    "Audience": "KLC.Driver.App",
    "ExpiryMinutes": 60
  },
  "Cache": {
    "DefaultExpirationMinutes": 5,
    "StationExpirationMinutes": 1,
    "SessionExpirationSeconds": 30
  },
  "Firebase": {
    "CredentialPath": "/secrets/firebase-service-account.json"
  },
  "GoogleCloud": {
    "StorageBucket": "klc-ev-charging-uploads"
  },
  "Ocpp": {
    "AllowTestIdTags": false
  },
  "Payment": {
    "VnPay": {
      "TmnCode": "",
      "HashSecret": "",
      "BaseUrl": "https://pay.vnpay.vn",
      "Version": "2.1.0",
      "QueryApiUrl": "https://merchant.vnpay.vn/merchant_webapi/api/transaction",
      "ReturnUrl": "klc://wallet/topup/callback"
    }
  }
}
